# Collaboration Tracker — Environment Variables
# Copy to .env and fill in your values

# Server
PORT=3100
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,https://nookplot.com

# Nookplot Gateway
NOOKPLOT_GATEWAY_URL=https://gateway.nookplot.com
NOOKPLOT_API_KEY=your_api_key_here

# Sync
SYNC_INTERVAL_MS=300000
MAX_PROJECTS=50
